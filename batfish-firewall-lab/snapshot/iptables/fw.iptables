*filter
:INPUT ACCEPT [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
-A FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
-A FORWARD -s 10.10.10.10/32 -d 10.20.20.10/32 -p tcp -m tcp --dport 80 -j ACCEPT
-A FORWARD -s 10.10.10.10/32 -d 10.20.20.10/32 -p tcp -m tcp --dport 22 -j DROP
-A FORWARD -s 10.10.10.0/24 -d 10.20.20.0/24 -p icmp -j ACCEPT
COMMIT
